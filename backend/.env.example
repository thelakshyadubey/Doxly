# ══════════════════════════════════════════════════════════════════════════════
# .env.example — copy to .env and fill in real values
# All variables are required unless marked optional.
# ══════════════════════════════════════════════════════════════════════════════

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_REASONING_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Google OAuth 2.0 (per-user Drive access) ──────────────────────────────────
# Create OAuth 2.0 credentials at console.cloud.google.com → APIs & Services → Credentials
# Credential type: Web application
# Add your callback URL to "Authorised redirect URIs"
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Name of the top-level folder created inside each user's own Google Drive.
# Documents are stored under: My Drive / {APP_FOLDER_NAME} / {session_id} / {doc_type} /
GOOGLE_DRIVE_APP_FOLDER_NAME=DocumentIntelligence

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=                            # leave empty for local persistent mode
QDRANT_API_KEY=                        # only required when QDRANT_URL is set
QDRANT_COLLECTION_NAME=documents
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_VECTOR_SIZE=768

# ── Neo4j (AuraDB free tier) ──────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Redis (Upstash free tier) ─────────────────────────────────────────────────
REDIS_URL=rediss://:your_password@your_host.upstash.io:6379

# ── Session windowing ─────────────────────────────────────────────────────────
SESSION_THRESHOLD_SECONDS=600

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=100
EMBEDDING_BATCH_SIZE=32

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
FINAL_TOP_K=6

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
